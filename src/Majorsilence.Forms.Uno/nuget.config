<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    The Uno packages are not available on the corporate feeds (they 403). Scope this project's
    restore to nuget.org only so it resolves Uno.WinUI / SkiaSharp.Views.Uno.WinUI cleanly without
    the corporate feeds' 403 aborting the restore.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
