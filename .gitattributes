# Normalize all text files to LF line endings on checkin, regardless of the
# checking-out platform's core.autocrlf setting (Windows defaults to CRLF
# checkouts otherwise, which is where this repo's line-ending churn came from).
* text=auto eol=lf

# Source code
*.cs text eol=lf diff=csharp
*.vb text eol=lf

# Project / solution / build files
*.csproj text eol=lf
*.vbproj text eol=lf
*.sln text eol=lf
*.slnx text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.config text eol=lf
*.editorconfig text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Scripts
*.sh text eol=lf
*.ps1 text eol=lf
*.bat text eol=lf
*.cmd text eol=lf

# Data / docs / config
*.json text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.manifest text eol=lf

# Binary files — never touch line endings, no diffing as text
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.dll binary
*.exe binary
*.pdb binary
*.snk binary
*.zip binary
*.gz binary
*.nupkg binary
